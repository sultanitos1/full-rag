{
  "info": {
    "name": "Mini-RAG Tourism API",
    "description": "RAG chatbot for tourism with MongoDB conversation history",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "opencode"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "32.195.230.191:5000"
    },
    {
      "key": "file_id",
      "value": ""
    },
    {
      "key": "conversation_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", ""]
        }
      }
    },
    {
      "name": "Create Conversation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.conversation_id) {",
              "  pm.collectionVariables.set(\"conversation_id\", jsonData.conversation_id);",
              "  console.log(\"conversation_id set to: \" + jsonData.conversation_id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/api/v1/nlp/conversation",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "nlp", "conversation"]
        }
      }
    },
    {
      "name": "Get Conversation",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/nlp/conversation/{{conversation_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "nlp", "conversation", "{{conversation_id}}"]
        }
      }
    },
    {
      "name": "List Conversations",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/nlp/conversations?ids=234821a310144b80a25e78633fdbf830,997c94007aa44a60bdc6d63b409189d3",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "nlp", "conversations"],
          "query": [
            {
              "key": "ids",
              "value": "234821a310144b80a25e78633fdbf830,997c94007aa44a60bdc6d63b409189d3"
            }
          ]
        }
      }
    },
    {
      "name": "Chat - First Message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Tell me about Cairo\",\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"limit\": 5\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/nlp/chat",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "nlp", "chat"]
        }
      }
    },
    {
      "name": "Chat - Follow-up (context-aware)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"What about hotels there?\",\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"limit\": 5\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/nlp/chat",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "nlp", "chat"]
        }
      }
    },
    {
      "name": "Chat - Greeting",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"hello\",\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"limit\": 5\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/nlp/chat",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "nlp", "chat"]
        }
      }
    },
    {
      "name": "Chat - Arabic",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"ما هي أفضل الفنادق في القاهرة؟\",\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"limit\": 5\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/nlp/chat",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "nlp", "chat"]
        }
      }
    },
    {
      "name": "Chat - Empty Query",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"\",\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"limit\": 5\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/nlp/chat",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "nlp", "chat"]
        }
      }
    },
    {
      "name": "Chat - No Match Fallback",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"What is the weather in Tokyo?\",\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"limit\": 5\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/nlp/chat",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "nlp", "chat"]
        }
      }
    },
    {
      "name": "Upload Multiple Files",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "files",
              "type": "file",
              "src": []
            },
            {
              "key": "files",
              "type": "file",
              "src": []
            },
            {
              "key": "chunk_size",
              "value": "500",
              "type": "text"
            },
            {
              "key": "overlap_size",
              "value": "20",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/v1/data/multi-upload",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "data", "multi-upload"]
        }
      }
    },
    {
      "name": "List Files",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/data/files",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "data", "files"]
        }
      }
    },
    {
      "name": "Update File",
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": []
            },
            {
              "key": "chunk_size",
              "value": "500",
              "type": "text"
            },
            {
              "key": "overlap_size",
              "value": "20",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/v1/data/file/{{file_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "data", "file", "{{file_id}}"]
        }
      }
    },
    {
      "name": "Delete File",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{base_url}}/api/v1/data/file/{{file_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "data", "file", "{{file_id}}"]
        }
      }
    }
  ]
}
